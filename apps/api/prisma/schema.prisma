generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

enum Role {
  buyer
  seller
  inspector
  admin
}

enum MenuDayStatus {
  draft
  published
}

enum OrderStatus {
  pending
  confirmed
  accepted
  declined
  preparing
  ready
  completed
  cancelled
}

enum Fulfillment {
  pickup
  delivery
}

enum DeliveryProvider {
  doordash
  grubhub
  mock
}

model User {
  id           String   @id @default(uuid())
  role         Role
  email        String   @unique
  passwordHash String
  phone        String?
  locale       String   @default("en")
  createdAt    DateTime @default(now())
  kitchen      Kitchen?
  orders       Order[]
  refreshTokens RefreshToken[]
  notifications Notification[]
  reviews      Review[]
  pollVotes    PollVote[]
  dishRequests DishRequest[]
  inspectionVisits InspectionVisit[]
  scoreDisputes ScoreDispute[]
}

// Story 4.4 (FR22): in-app inbox is the source of truth; push/email channels fan out
// from the same rows once FCM/SES credentials exist.
model Notification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
}

model Kitchen {
  id                   String    @id @default(uuid())
  sellerId             String    @unique
  seller               User      @relation(fields: [sellerId], references: [id])
  name                 String
  cuisineTag           String
  description          String
  photos               String[]
  addressEncrypted     String
  // geo: geography(Point,4326) — raw SQL migration ile eklenir (Prisma native desteklemiyor)
  complianceAttestedAt DateTime?
  attestationIp        String?
  ratingAvg            Float?
  ratingCount          Int       @default(0)
  hygieneScoreTotal    Int?
  hygieneScoredAt      DateTime?
  menuDays             MenuDay[]
  orders               Order[]
  reviews              Review[]
  polls                Poll[]
  dishRequests         DishRequest[]
  healthReports        HealthReport[]
  inspectionVisits     InspectionVisit[]
  scoreDisputes        ScoreDispute[]
  createdAt            DateTime  @default(now())
}

// Story 7.3 (FR20 follow-up): sellers dispute a hygiene score; an admin dismisses the
// dispute (score stands) or annuls the badge (kitchen returns to "Not yet inspected"
// until re-inspection — the HygieneScore row itself is never edited, only the badge).
model ScoreDispute {
  id         String    @id @default(uuid())
  kitchenId  String
  kitchen    Kitchen   @relation(fields: [kitchenId], references: [id])
  openedById String
  openedBy   User      @relation(fields: [openedById], references: [id])
  reason     String
  status     String    @default("open") // open | dismissed | annulled
  adminNote  String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([status, createdAt])
}

// Story 7.2 (FR20): admin-assigned inspection visits; the inspector sees the street
// address only for their own assigned visits (NFR5 scoping). status: assigned | scored.
model InspectionVisit {
  id           String        @id @default(uuid())
  kitchenId    String
  kitchen      Kitchen       @relation(fields: [kitchenId], references: [id])
  inspectorId  String
  inspector    User          @relation(fields: [inspectorId], references: [id])
  scheduledAt  DateTime
  status       String        @default("assigned")
  score        HygieneScore?
  createdAt    DateTime      @default(now())

  @@index([inspectorId, scheduledAt])
}

// Submit-once (visitId UNIQUE): edits go through the admin dispute flow (Story 7.3).
// The badge is denormalized to Kitchen.hygieneScoreTotal/hygieneScoredAt on submit.
model HygieneScore {
  id          String          @id @default(uuid())
  visitId     String          @unique
  visit       InspectionVisit @relation(fields: [visitId], references: [id])
  total       Int
  subScores   Json            // {storage, prepSurfaces, temperatureControl, personalHygiene, documentation} 0-20 each
  photos      String[]
  submittedAt DateTime        @default(now())
}

// Story 7.1 (FR19): seller-uploaded health/permit documents (PDF or image), shown on
// the public kitchen profile with their upload date.
model HealthReport {
  id         String   @id @default(uuid())
  kitchenId  String
  kitchen    Kitchen  @relation(fields: [kitchenId], references: [id])
  fileUrl    String
  filename   String
  uploadedAt DateTime @default(now())

  @@index([kitchenId, uploadedAt])
}

// Story 6.1 (FR16): one review per completed order; Kitchen.ratingAvg/ratingCount are
// denormalized aggregates recomputed on insert.
model Review {
  id        String   @id @default(uuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id])
  kitchenId String
  kitchen   Kitchen  @relation(fields: [kitchenId], references: [id])
  buyerId   String
  buyer     User     @relation(fields: [buyerId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([kitchenId, createdAt])
}

// Story 6.2 (FR17): a seller polls buyers on candidate upcoming menu items.
// options is a fixed list of choice labels; PollVote enforces one vote per buyer.
model Poll {
  id        String     @id @default(uuid())
  kitchenId String
  kitchen   Kitchen    @relation(fields: [kitchenId], references: [id])
  question  String
  options   String[]
  closesAt  DateTime?
  createdAt DateTime   @default(now())
  votes     PollVote[]

  @@index([kitchenId, createdAt])
}

model PollVote {
  id          String   @id @default(uuid())
  pollId      String
  poll        Poll     @relation(fields: [pollId], references: [id])
  buyerId     String
  buyer       User     @relation(fields: [buyerId], references: [id])
  optionIndex Int
  createdAt   DateTime @default(now())

  @@unique([pollId, buyerId]) // FR17: one vote per buyer per poll
}

// Story 6.3 (FR18): a buyer asks a kitchen for a dish/cuisine; the seller accepts
// (notifying the requester) or declines. status: open | accepted | declined.
model DishRequest {
  id         String   @id @default(uuid())
  kitchenId  String
  kitchen    Kitchen  @relation(fields: [kitchenId], references: [id])
  buyerId    String
  buyer      User     @relation(fields: [buyerId], references: [id])
  text       String
  status     String   @default("open")
  sellerNote String?
  createdAt  DateTime @default(now())

  @@index([kitchenId, createdAt])
  @@index([buyerId, createdAt])
}

model Dish {
  id          String   @id @default(uuid())
  kitchenId   String
  name        String
  description String
  photo       String?
  priceCents  Int
  dietaryTags String[]
  menuItems   MenuItem[]
}

model MenuDay {
  id           String        @id @default(uuid())
  kitchenId    String
  kitchen      Kitchen       @relation(fields: [kitchenId], references: [id])
  date         DateTime      @db.Date
  status       MenuDayStatus @default(draft)
  readyWindows Json          // [{start:"17:00",end:"20:00",slotMinutes:30}]
  items        MenuItem[]
  @@unique([kitchenId, date])
}

model MenuItem {
  id                String  @id @default(uuid())
  menuDayId         String
  menuDay           MenuDay @relation(fields: [menuDayId], references: [id])
  dishId            String
  dish              Dish    @relation(fields: [dishId], references: [id])
  portionsTotal     Int
  portionsRemaining Int
  orderItems        OrderItem[]
}

model Order {
  id              String      @id @default(uuid())
  buyerId         String
  buyer           User        @relation(fields: [buyerId], references: [id])
  kitchenId       String
  kitchen         Kitchen     @relation(fields: [kitchenId], references: [id])
  menuDayId       String
  status          OrderStatus @default(pending)
  readySlot       DateTime
  fulfillment     Fulfillment
  totalCents      Int
  commissionCents Int         @default(0)
  paymentIntentId String?
  idempotencyKey  String      @unique
  items           OrderItem[]
  deliveryJob     DeliveryJob?
  review          Review?
  createdAt       DateTime    @default(now())
}

model OrderItem {
  id             String   @id @default(uuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id])
  menuItemId     String
  menuItem       MenuItem @relation(fields: [menuItemId], references: [id])
  qty            Int
  unitPriceCents Int
}

model DeliveryJob {
  id          String           @id @default(uuid())
  orderId     String           @unique
  order       Order            @relation(fields: [orderId], references: [id])
  provider    DeliveryProvider
  externalId  String?
  status      String           @default("created")
  trackingUrl String?
  feeCents    Int              @default(0)
}

model AuditLog {
  id      String   @id @default(uuid())
  actor   String
  entity  String
  action  String
  before  Json?
  after   Json?
  at      DateTime @default(now())
}
