DATABASE_URL=postgresql://culture:culture@localhost:5432/culture_eats
REDIS_URL=redis://localhost:6379
# Must be >= 32 bytes (HS256 key requirement) — shared by apps/api (NestJS) and
# apps/api-java so access tokens issued by either backend are valid on both.
JWT_SECRET=please-change-this-jwt-secret-in-prod-32b
JWT_REFRESH_SECRET=change-me-too
ADDRESS_ENC_KEY=32-byte-hex-key-change-me-0000000000
API_PORT=3001
MCP_PORT=3002
ANTHROPIC_API_KEY=sk-ant-...
# Chat agent provider: google-genai (dev, free tier) or anthropic (full version)
AI_PROVIDER=google-genai
# Free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# JWT token for MCP server stdio mode (copy a buyer access_token from /auth/login)
CULTURE_EATS_TOKEN=

# --- apps/api-java (Spring Boot 4 + Spring AI) ---
# Shares the culture_eats database with the NestJS service (strangler migration).
DB_USER=culture
DB_PASSWORD=culture
JAVA_API_PORT=8080
# Frontend (apps/web) and MCP server talk to the Java API as their single base URL.
NEXT_PUBLIC_API_URL=http://localhost:8080
API_URL=http://localhost:8080
# Delivery (Epic 4): mock provider until DoorDash/Grubhub sandbox credentials exist.
DELIVERY_PROVIDER=mock
DELIVERY_WEBHOOK_SECRET=dev-delivery-webhook-secret
# Payments (Story 3.4): mock settles orders instantly (no keys needed). Set to "stripe"
# with test keys to take real PaymentIntents; webhook secret comes from
# `stripe listen --forward-to localhost:8080/webhooks/stripe`.
PAYMENTS_PROVIDER=mock
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Notifications (Story 4.4): in-app inbox always on; external channel is log-only until
# FCM (push) / SES (email) credentials exist.
NOTIFICATIONS_CHANNEL=log
